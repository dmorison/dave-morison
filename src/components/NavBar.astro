---
import { Icon } from 'astro-icon/components';
---

<nav>
	<header>
		<ul class="home">
			<li><a href="/dave-morison">Dave Morison - Web Analyst</a></li>
		</ul>
		<ul class="nav-items">
			<li><a href="/dave-morison#pitch">Why Me?</a></li>
			<li><a href="/dave-morison#services">Services</a></li>
			<li><a href="/dave-morison#tech">Tech Stack</a></li>
		</ul>
		<ul class="contact">
			<li><a href="#contact">Contact</a></li>
			<li>
				<a href="https://www.linkedin.com/in/david-morison/" target="_blank" rel="noopener noreferrer">
					<Icon name="LinkedIn" size="30" />
				</a>
			</li>
		</ul>
	</header>
</nav>

<script type="module">
	if (typeof window !== 'undefined') {
		const header = document.querySelector('header');
		const shrinkThreshold = 50;

		const onScroll = () => {
			if (!header) return;
			window.scrollY > shrinkThreshold
				? header.classList.add('header--small')
				: header.classList.remove('header--small');
		};

		window.addEventListener('scroll', onScroll, { passive: true });
		onScroll();
	}
</script>

<style>
	nav {
		position: sticky;
		top: 0;
		z-index: 10;
	}

	header {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		padding: 1em;
		background-color: #9BC0DA;
		transition: padding 250ms ease, background-color 250ms ease, box-shadow 250ms ease;
	}

	header.header--small {
		padding: 1em;
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
	}
	header.header--small ul.nav-items {
		background-color: transparent;
		padding: 0 2em;
		margin-top: 0.75em;
	}

	ul {
		padding: 0;
		margin: 0;
	}

	ul.nav-items {
		display: flex;
		justify-content: space-evenly;
		width: 100%;
		margin-top: 1em;
		order: 3;
		gap: 1.5em;
		background-color: #E8F5FD;
		padding: 1em;
		border-radius: 2em;
		transition: padding 250ms ease, background-color 250ms ease;
	}

	ul.home {
		max-width: 110px;
		overflow: visible;
	}
	ul.home > li {
		width: max-content;
		font-weight: bold;
	}

	ul.contact {
		display: flex;
		gap: 1em;
		align-items: center;
	}

	li {
		list-style: none;
	}

	a {
		color: #012C3C;
		text-decoration: none;
		font-weight: bold;
	}

	a:hover {
		text-decoration: underline;
	}

	@media screen and (min-width: 768px) {
		header {
			padding: 1em 4em;
		}

		header.header--small ul.nav-items {
			margin-top: 0;
		}
		
		ul.nav-items {
			width: fit-content;
			order: 2;
			padding: 1em 2em;
		}
		
		ul.home {
			order: 1;
		}

		ul.contact {
			order: 3;
		}
	}
</style>