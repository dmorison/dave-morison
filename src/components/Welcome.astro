---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import dataImage from '../assets/data-image.png';
import performanceImage from '../assets/performance-image.png';
import NavBar from './NavBar.astro';
import Hero from './Hero.astro';
import Tech from './Tech.astro';
import ContactForm from './ContactForm.astro';
---

<div id="container">
	<main>
		<NavBar />
		<div class="content">
			<section id="hero">
				<Hero />
			</section>
			<section id="pitch">
				<h3>Technical Edge</h3>
				<div class="cards-wrapper">
					<div class="card card-one">
						<p>I'll take care of the technical implementation, helping you make strategic business decisions based on accurate data.</p>
						<p>With a background in web development and a passion for data, I bridge the gap between technical implementation and business insights.</p>
						<a href="/dave-morison/about" class="about-me">More about me</a>
					</div>
					<div class="card">
						<div class="card-inner">
							<div>
								<h4>Clean Data</h4>
								<p>I write custom scripts to get the data you need, ensuring accuracy and reliability.</p>
							</div>
							<Image src={dataImage} alt="Google Analytics dashboard" width={250} />
						</div>
					</div>
					<div class="card">
						<div class="card-inner">
							<div>
								<h4>Performance</h4>
								<p>I implement lean tagging, so that tracking doesn't affect your website's performance.</p>
							</div>
							<Image src={performanceImage} alt="Google Analytics dashboard" width={250} />
						</div>
					</div>
				</div>
			</section>
			<section id="services">
				<h3>Services</h3>
				<div class="cards-wrapper">
					<div class="card">
						<h4>The Foundation</h4>
						<p><strong>GA4 setup from scratch and ensure most relevant information is easily accessible</strong></p>
						<ul>
							<li><Icon name="check" size="20" />Install GA4 and configure data streams</li>
							<li><Icon name="check" size="20" />Ensure events are being recorded correctly</li>
							<li><Icon name="check" size="20" />Customize existing default reports and report collections</li>
							<li><Icon name="check" size="20" />Implement data management: Cross-domain measurement, Unwanted referrals, Data filters</li>
						</ul>
						<p><u>Extras:</u> Install GTM and Configure GA4 Recommended events specific to your business objectives</p>
					</div>
					<div class="card">
						<h4>The Tracking Rescue</h4>
						<p><strong>Technical audit - clean up and optimise</strong></p>
						<ul>
							<li><Icon name="check" size="20" />Audit current configuration</li>
							<li><Icon name="check" size="20" />Find duplicate tags</li>
							<li><Icon name="check" size="20" />Fix broken event triggers</li>
						</ul>
						<p>Ensure your setup is inline with everything listed under "The Foundation"</p>
					</div>
					<div class="card">
						<h4>The Custom Framework</h4>
						<p><strong>Collect additional information that Google Analytics does not collect automatically</strong></p>
						<ul>
							<li><Icon name="check" size="20" />Set up custom tags in GTM specific to your business needs</li>
							<li><Icon name="check" size="20" />Configure custom variables and triggers</li>
							<li><Icon name="check" size="20" />Implement scripts for reusable tracking logic</li>
						</ul>
					</div>
					<div class="card">
						<h4>The Explorer</h4>
						<p><strong>Custom reports using advance techniques that go beyond the standard reports to help you uncover deeper insights about your customers behaviour</strong></p>
						<ul>
							<li><Icon name="check" size="20" />Compare multiple metrics in a visually appropriate way</li>
							<li><Icon name="check" size="20" />Unlock hidden insights with enhanced segmentation and audience analysis</li>
							<li><Icon name="check" size="20" />Better understand user behavior through Path and Funnel explorations</li>
						</ul>
					</div>
					<!-- <div class="card">
						<h4>The Visualization</h4>
						<p><strong>Custom dashboards</strong></p>
						<ul>
							<li><Icon name="check" size="20" />Looker Studio</li>
							<li><Icon name="check" size="20" />Tableau</li>
							<li><Icon name="check" size="20" />Power BI</li>
						</ul>
					</div> -->
				</div>
			</section>
			<section id="tech">
				<h3>Tech Stack</h3>
				<Tech />
			</section>
		</div>
		<section id="contact">
			<div class="contact-inner">
				<h3>Contact</h3>
				<ContactForm />
			</div>
		</section>
	</main>
</div>

<style>
	#container {
		font-family: var(--font-montserrat), Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		color: #012C3C;
	}

	.content {
		height: 100%;
		background: linear-gradient(to bottom, #9BC0DA, #ffffff);
	}

	section {
		padding: 1em;
	}

	#services .card {
		background-color: #ffffff;
	}

	#tech {
		text-align: center;
	}

	#contact{
		display: flex;
		justify-content: center;
		background-color: #1B5B7E;
		color: #E8F5FD;
	}

	.contact-inner {
		display: flex;
		flex-direction: column;
		justify-content: space-around;
		padding: 1em;
	}

	h3 {
		font-size: 23px;
		margin-top: 0;
	}

	h4 {
		margin-top: 0;
		margin-bottom: 0.5em;
		text-decoration: underline;
	}

	p {
		font-size: 16px;
		line-height: 24px;
		letter-spacing: -0.006em;
		margin: 0;
	}

	.card ul {
		padding-left: 0;
		list-style-type: none;
	}
	.card ul li {
		display: flex;
		align-items: center;
		gap: 0.5em;
		margin-bottom: 0.5em;
	}
	.card ul li > svg {
		min-width: 20px;
	}

	.cards-wrapper {
		display: flex;
		flex-direction: column;
		gap: 2em;
		margin: 1em 0;
	}

	.card {
		flex: 1;
		background-color: #E8F5FD;
		padding: 1em;
		border-radius: 8px;
		box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
	}

	.card-inner {
		display: flex;
		flex-direction: column-reverse;
		align-items: center;
		text-align: center;
	}

	.card-inner > div {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
	}

	.card-one {
		max-width: 300px;
		background-color: transparent;
		padding-left: 0;
		padding-bottom: 0;
		box-shadow: none;
	}
	.card-one p:first-child {
		margin-bottom: 1em;
	}

	.about-me {
		display: inline-block;
		margin-top: 1em;
		padding: 0.75em 1.5em;
		background-color: #1B5B7E;
		color: #ffffff;
		font-weight: bold;
		text-decoration: none;
		border-radius: 2em;
		font-size: 16px;
		border: none;
		transition: background-color 300ms ease, color 300ms ease;
	}
	.about-me:hover {
		background-color: #ffffff;
		color: #1B5B7E;
	}

	@media screen and (min-width: 768px) {
		section {
			padding: 4em;
		}

		#pitch, #services {
			max-width: 1400px;
			margin: 0 auto;
		}

		.contact-inner {
			width: 500px;
		}

		.cards-wrapper {
			flex-direction: row;
			gap: 2em;
			margin: 1em 0;
		}

		.card-inner {
			flex-direction: row;
			text-align: left;
		}

		.card-inner > div {
			align-items: flex-start;
		}
	}
</style>

